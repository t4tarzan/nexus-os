# Nexus — Environment Configuration

# LLM Provider (choose one)
# Options: deepseek, anthropic, ollama
NEXUS_LLM_PROVIDER=deepseek
NEXUS_LLM_MODEL=deepseek-chat

# API Keys (fill in ONE)
DEEPSEEK_API_KEY=sk-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Server
NEXUS_PORT=47900

# Graph Database (optional, default: ~/.nexus/graph.db)
# NEXUS_DB_PATH=~/.nexus/graph.db

# Observer interval in ms (default: 30000)
# NEXUS_OBSERVER_INTERVAL=30000

# Ollama (if using local LLM)
# OLLAMA_URL=http://localhost:11434
