{
  "name": "Nexus Browser Connect",
  "version": "0.2.0",
  "description": "Send web content to Nexus OS for processing",
  "manifest_version": 3,
  "permissions": ["activeTab", "contextMenus", "scripting", "storage"],
  "host_permissions": ["http://localhost:47900/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Send to Nexus"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "send-to-nexus": {
      "suggested_key": { "default": "Ctrl+Shift+N", "mac": "Command+Shift+N" },
      "description": "Send selected text to Nexus"
    }
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"]
  }]
}
